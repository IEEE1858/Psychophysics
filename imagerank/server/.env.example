# Copy to server/.env (gitignored) for local dev, or set these in the process
# environment in production. On startup the server idempotently seeds this admin
# account if both are set. Leave unset once an admin exists in the database.
ADMIN_SEED_USERNAME=henrykoren
ADMIN_SEED_PASSWORD=change-me

# Optional: override the SQLite database location (defaults to server/data/).
# DB_PATH=/var/lib/imagerank/psychophysics.db

# --- Participant accounts / sign-in (issue #31) ---
# Secret used to sign participant session tokens (HMAC-SHA256). Required in
# production so sessions survive restarts; generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_TOKEN_SECRET=change-me

# Google OAuth (optional — sign-in still works with email/password if unset).
# Create a "Web application" OAuth client in the Google Cloud console and add the
# redirect URI below as an authorized redirect URI.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Local dev goes through the Vite proxy; production is the public URL.
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/api/auth/google/callback
# GOOGLE_OAUTH_REDIRECT_URI=https://imagerank.imatest.com/api/auth/google/callback
